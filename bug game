<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Bug Mario</title>
  <style>
    body { margin:0; background:#0b1020; color:#e8ecff; font-family:system-ui, Arial; }
    .wrap { max-width: 980px; margin: 0 auto; padding: 14px; }
    .hud { display:flex; gap:12px; margin-bottom:10px; flex-wrap:wrap; }
    .pill { padding:6px 10px; border:1px solid rgba(255,255,255,.18); border-radius:999px; background:rgba(255,255,255,.06); }
    canvas { width:100%; background: linear-gradient(#1b2b63, #0b1020); border:1px solid rgba(255,255,255,.15); border-radius:14px; }
    .hint { margin-top:10px; opacity:.85; font-size:14px; line-height:1.35; }
    code { opacity:.9; }
  </style>
</head>
<body>
<div class="wrap">
  <div class="hud">
    <div class="pill">Score: <span id="score">0</span></div>
    <div class="pill">Lives: <span id="lives">3</span></div>
    <div class="pill">Coins: <span id="coins">0</span></div>
  </div>

  <canvas id="game" width="980" height="520"></canvas>

  <div class="hint">
    Controles: <b>← →</b> mover · <b>↑</b> o <b>Space</b> saltar · Pisa un bug para matarlo.<br/>
    Tip: Ajusta la “sensación Mario” tocando <code>GRAVITY</code>, <code>JUMP</code>, <code>MOVE</code>.
  </div>
</div>

<script>
  // ====== CONFIG (feel) ======
  const GRAVITY = 0.85;
  const MOVE = 3.2;
  const JUMP = 14.5;
  const FRICTION = 0.82;

  // ====== SETUP ======
  const canvas = document.getElementById("game");
  const ctx = canvas.getContext("2d");

  const scoreEl = document.getElementById("score");
  const livesEl = document.getElementById("lives");
  const coinsEl = document.getElementById("coins");

  const keys = new Set();
  addEventListener("keydown", (e) => { if (e.code==="Space") e.preventDefault(); keys.add(e.code); });
  addEventListener("keyup", (e) => keys.delete(e.code));

  const clamp = (v,min,max)=>Math.max(min,Math.min(max,v));

  // World is wider than the screen (simple side scroll)
  const world = { w: 2400, h: canvas.height };

  // Player
  const p = {
    x: 80, y: 0,
    w: 26, h: 32,
    vx: 0, vy: 0,
    onGround: false,
    lives: 3,
    score: 0,
    coins: 0
  };

  // Platforms (x,y,w,h) in world coordinates
  const platforms = [
    { x: 0,    y: 480, w: 2400, h: 40 }, // ground
    { x: 240,  y: 390, w: 160,  h: 18 },
    { x: 470,  y: 330, w: 170,  h: 18 },
    { x: 740,  y: 410, w: 190,  h: 18 },
    { x: 1040, y: 360, w: 180,  h: 18 },
    { x: 1340, y: 300, w: 210,  h: 18 },
    { x: 1650, y: 410, w: 220,  h: 18 },
    { x: 1980, y: 350, w: 200,  h: 18 },
  ];

  // Coins
  const coins = [
    { x: 280, y: 350, r: 7, taken:false },
    { x: 320, y: 350, r: 7, taken:false },
    { x: 520, y: 290, r: 7, taken:false },
    { x: 560, y: 290, r: 7, taken:false },
    { x: 790, y: 370, r: 7, taken:false },
    { x: 1100, y: 320, r: 7, taken:false },
    { x: 1420, y: 260, r: 7, taken:false },
    { x: 1710, y: 370, r: 7, taken:false },
    { x: 2040, y: 310, r: 7, taken:false },
  ];

  // Bugs (enemies)
  const bugs = [
    { x: 620,  y: 0, w: 26, h: 18, vx: 1.1, vy: 0, alive:true },
    { x: 1180, y: 0, w: 26, h: 18, vx: 1.2, vy: 0, alive:true },
    { x: 1750, y: 0, w: 26, h: 18, vx: 1.25, vy: 0, alive:true },
    { x: 2140, y: 0, w: 26, h: 18, vx: 1.35, vy: 0, alive:true },
  ];

  // Camera
  const cam = { x: 0 };

  // AABB collision helpers
  function rectsOverlap(a,b){
    return a.x < b.x + b.w && a.x + a.w > b.x && a.y < b.y + b.h && a.y + a.h > b.y;
  }

  function resolvePlatformCollisions(entity){
    // Basic platform collision: separate axis using previous velocity direction
    entity.onGround = false;

    // Horizontal move
    entity.x += entity.vx;
    for (const pl of platforms){
      if (rectsOverlap(entity, pl)){
        if (entity.vx > 0) entity.x = pl.x - entity.w;
        else if (entity.vx < 0) entity.x = pl.x + pl.w;
        entity.vx = 0;
      }
    }

    // Vertical move
    entity.y += entity.vy;
    for (const pl of platforms){
      if (rectsOverlap(entity, pl)){
        if (entity.vy > 0){
          entity.y = pl.y - entity.h;
          entity.vy = 0;
          entity.onGround = true;
        } else if (entity.vy < 0){
          entity.y = pl.y + pl.h;
          entity.vy = 0;
        }
      }
    }
  }

  function resetPlayer(){
    p.x = 80; p.y = 0; p.vx = 0; p.vy = 0;
    cam.x = 0;
  }

  // ====== UPDATE ======
  let last = performance.now();
  function loop(now){
    const dt = Math.min(32, now - last); // cap
    last = now;

    update(dt);
    draw();

    requestAnimationFrame(loop);
  }

  function update(){
    // Input
    const left  = keys.has("ArrowLeft") || keys.has("KeyA");
    const right = keys.has("ArrowRight") || keys.has("KeyD");
    const jump  = keys.has("ArrowUp") || keys.has("KeyW") || keys.has("Space");

    if (left)  p.vx -= 0.55;
    if (right) p.vx += 0.55;
    p.vx *= FRICTION;
    p.vx = clamp(p.vx, -MOVE, MOVE);

    // Gravity
    p.vy += GRAVITY;
    p.vy = clamp(p.vy, -30, 22);

    // Jump (only if on ground)
    if (jump && p.onGround){
      p.vy = -JUMP;
      p.onGround = false;
    }

    // Collide player with platforms
    resolvePlatformCollisions(p);

    // Keep in world bounds
    p.x = clamp(p.x, 0, world.w - p.w);
    if (p.y > world.h + 200){
      // fell off
      loseLife();
    }

    // Update bugs
    for (const b of bugs){
      if (!b.alive) continue;

      b.vy += GRAVITY;
      b.vy = clamp(b.vy, -30, 22);

      // Simple AI: walk back and forth; turn when hit wall/edge-ish (by collision)
      const oldX = b.x;
      b.vx = clamp(b.vx, -1.8, 1.8);

      // move + collide
      resolvePlatformCollisions(b);

      // If bug got stuck horizontally, flip direction
      if (Math.abs(b.x - oldX) < 0.01) b.vx *= -1;

      // tiny “edge” handling: if on ground, probe a bit forward; if no ground, flip
      if (b.onGround){
        const probe = {
          x: b.x + (b.vx > 0 ? b.w + 2 : -2),
          y: b.y + b.h + 1,
          w: 2, h: 2
        };
        let supported = false;
        for (const pl of platforms){
          if (rectsOverlap(probe, pl)){ supported = true; break; }
        }
        if (!supported) b.vx *= -1;
      }
    }

    // Coins collection
    for (const c of coins){
      if (c.taken) continue;
      const cx = c.x, cy = c.y;
      const nearestX = clamp(cx, p.x, p.x + p.w);
      const nearestY = clamp(cy, p.y, p.y + p.h);
      const dx = cx - nearestX;
      const dy = cy - nearestY;
      if (dx*dx + dy*dy <= c.r*c.r){
        c.taken = true;
        p.coins += 1;
        p.score += 1;
        coinsEl.textContent = String(p.coins);
        scoreEl.textContent = String(p.score);
      }
    }

    // Player vs bugs
    for (const b of bugs){
      if (!b.alive) continue;
      if (!rectsOverlap(p, b)) continue;

      // Determine if stomp: player falling and player's feet above bug top
      const playerBottom = p.y + p.h;
      const bugTop = b.y;
      const falling = p.vy > 0;

      if (falling && playerBottom - p.vy <= bugTop + 6){
        // stomp kill
        b.alive = false;
        p.vy = -JUMP * 0.7; // bounce
        p.score += 3;
        scoreEl.textContent = String(p.score);
      } else {
        // hit from side
        loseLife();
        break;
      }
    }

    // Camera follow
    cam.x = clamp(p.x - canvas.width * 0.45, 0, world.w - canvas.width);
  }

  function loseLife(){
    p.lives -= 1;
    livesEl.textContent = String(p.lives);
    if (p.lives <= 0){
      // restart full game
      p.lives = 3;
      p.score = 0;
      p.coins = 0;
      scoreEl.textContent = "0";
      coinsEl.textContent = "0";
      livesEl.textContent = "3";
      // revive bugs + reset coins
      for (const b of bugs){ b.alive = true; b.y = 0; b.vy = 0; }
      for (const c of coins){ c.taken = false; }
    }
    resetPlayer();
  }

  // ====== DRAW ======
  function draw(){
    ctx.clearRect(0,0,canvas.width,canvas.height);

    // parallax stars
    ctx.globalAlpha = 0.35;
    for (let i=0;i<80;i++){
      const x = ((i*97) % canvas.width) + (cam.x*0.15)%canvas.width;
      const y = (i*53) % canvas.height;
      ctx.fillRect(x%canvas.width, y, 1, 1);
    }
    ctx.globalAlpha = 1;

    // world offset
    ctx.save();
    ctx.translate(-cam.x, 0);

    // platforms
    for (const pl of platforms){
      ctx.fillStyle = "rgba(255,255,255,0.12)";
      ctx.fillRect(pl.x, pl.y, pl.w, pl.h);

      // top highlight
      ctx.fillStyle = "rgba(120,200,255,0.18)";
      ctx.fillRect(pl.x, pl.y, pl.w, 3);
    }

    // coins
    for (const c of coins){
      if (c.taken) continue;
      ctx.beginPath();
      ctx.arc(c.x, c.y, c.r, 0, Math.PI*2);
      ctx.fillStyle = "rgba(255,230,140,0.95)";
      ctx.fill();
      ctx.strokeStyle = "rgba(0,0,0,0.35)";
      ctx.lineWidth = 2;
      ctx.stroke();
    }

    // bugs
    for (const b of bugs){
      if (!b.alive) continue;

      // legs
      ctx.strokeStyle = "rgba(255,255,255,0.35)";
      ctx.lineWidth = 2;
      for (let k=0;k<6;k++){
        const px = b.x + (k<3 ? 6 + k*6 : 6 + (k-3)*6);
        const top = b.y + b.h;
        ctx.beginPath();
        ctx.moveTo(px, top);
        ctx.lineTo(px + (k<3 ? -5 : 5), top + 8);
        ctx.stroke();
      }

      // body
      ctx.fillStyle = "rgba(255,90,120,0.92)";
      ctx.beginPath();
      ctx.roundRect(b.x, b.y, b.w, b.h, 8);
      ctx.fill();

      // eyes
      ctx.fillStyle = "rgba(0,0,0,0.55)";
      ctx.beginPath();
      ctx.arc(b.x + 8, b.y + 7, 2.2, 0, Math.PI*2);
      ctx.arc(b.x + 18, b.y + 7, 2.2, 0, Math.PI*2);
      ctx.fill();
    }

    // player (muñequito)
    ctx.fillStyle = "rgba(255,255,255,0.95)";
    ctx.beginPath();
    ctx.roundRect(p.x, p.y, p.w, p.h, 8);
    ctx.fill();

    // visor / “gorra”
    ctx.fillStyle = "rgba(120,200,255,0.95)";
    ctx.beginPath();
    ctx.roundRect(p.x + 4, p.y + 6, p.w - 8, 8, 6);
    ctx.fill();

    // outline
    ctx.strokeStyle = "rgba(0,0,0,0.35)";
    ctx.lineWidth = 2;
    ctx.strokeRect(p.x + 0.5, p.y + 0.5, p.w - 1, p.h - 1);

    ctx.restore();

    // screen vignette
    ctx.fillStyle = "rgba(0,0,0,0.14)";
    ctx.fillRect(0,0,canvas.width,canvas.height);
  }

  // Polyfill-ish: roundRect for older browsers
  if (!CanvasRenderingContext2D.prototype.roundRect) {
    CanvasRenderingContext2D.prototype.roundRect = function(x,y,w,h,r){
      r = Math.min(r, w/2, h/2);
      this.beginPath();
      this.moveTo(x+r, y);
      this.arcTo(x+w, y, x+w, y+h, r);
      this.arcTo(x+w, y+h, x, y+h, r);
      this.arcTo(x, y+h, x, y, r);
      this.arcTo(x, y, x+w, y, r);
      this.closePath();
      return this;
    };
  }

  resetPlayer();
  requestAnimationFrame(loop);
</script>
</body>
</html>
